# JDCloud AX1800 Pro - MgrServer 固件配置
# 仅保留 MgrServer 核心依赖，移除无关功能插件

CONFIG_TARGET_qualcommax=y
CONFIG_TARGET_qualcommax_ipq60xx=y
CONFIG_TARGET_qualcommax_ipq60xx_DEVICE_jdcloud_re-ss-01=y
CONFIG_TARGET_ROOTFS_SQUASHFS=y

# ============================================================
# 基础系统 (OpenWrt 官方必需)
# ============================================================
CONFIG_PACKAGE_base-files=y
CONFIG_PACKAGE_busybox=y
CONFIG_PACKAGE_dropbear=y
CONFIG_PACKAGE_firewall4=y
CONFIG_PACKAGE_nftables=y
CONFIG_PACKAGE_kmod-nft-offload=y
CONFIG_PACKAGE_netifd=y
CONFIG_PACKAGE_uci=y
CONFIG_PACKAGE_uci-compat=y
CONFIG_PACKAGE_uci-opkg=y
CONFIG_PACKAGE_opkg=y
CONFIG_PACKAGE_rpcd=y
CONFIG_PACKAGE_rpcd-mod-luci=y
CONFIG_PACKAGE_rpcd-mod-rpcsys=y

# ============================================================
# 网络核心
# ============================================================
CONFIG_PACKAGE_dnsmasq-full=y
CONFIG_PACKAGE_odhcp6c=y
CONFIG_PACKAGE_swconfig=y
CONFIG_PACKAGE_iwinfo=y
CONFIG_PACKAGE_wpad-basic=n
CONFIG_PACKAGE_wpad-mesh-openssl=y
CONFIG_PACKAGE_hostapd-openssl=y
CONFIG_PACKAGE_hostapd-utils=y
CONFIG_PACKAGE_iw=y
CONFIG_PACKAGE_ip-full=y
CONFIG_PACKAGE_kmod-tun=y
CONFIG_PACKAGE_kmod-inet-diag=y
CONFIG_PACKAGE_kmod-nft-queue=y
CONFIG_PACKAGE_miniupnpd=y

# ============================================================
# 硬件加速
# 当前源码树仅提供 qualcommax 目标默认的 qca-nss-dp 数据通路加速；
# 不声明源码树中不存在的 qca-nss-drv/ecm/crypto/clients/ifb 全栈特性。
# ============================================================

# ============================================================
# eBPF 内核支持
# NOTE: kmod-sched-bpf removed - requires act_bpf.ko which fails on qualcommax.
# Keeping BPF syscall/JIT for future use.
# ============================================================
CONFIG_BPF=y
CONFIG_BPF_SYSCALL=y
CONFIG_BPF_JIT=y
CONFIG_BPF_JIT_DEFAULT_ON=y

# ============================================================
# USB 核心 (MgrServer USB 设备管理)
# ============================================================
CONFIG_PACKAGE_kmod-usb-core=y
CONFIG_PACKAGE_kmod-usb2=y
CONFIG_PACKAGE_kmod-usb-ohci=y
CONFIG_PACKAGE_kmod-usb-acm=y
CONFIG_PACKAGE_kmod-usb-net=y
CONFIG_PACKAGE_kmod-usb-net-rndis=y
CONFIG_PACKAGE_kmod-usb-serial=y
CONFIG_PACKAGE_kmod-usb-serial-option=y
CONFIG_PACKAGE_kmod-usb3=y

# ============================================================
# LuCI (基础管理界面, 移至 :3500)
# ============================================================
CONFIG_PACKAGE_luci=y
CONFIG_PACKAGE_luci-base=y
CONFIG_PACKAGE_luci-compat=y
CONFIG_PACKAGE_luci-mod-network=y
CONFIG_PACKAGE_luci-mod-status=y
CONFIG_PACKAGE_luci-mod-system=y
CONFIG_PACKAGE_luci-i18n-base-zh-cn=y
CONFIG_PACKAGE_luci-i18n-firewall-zh-cn=y
CONFIG_PACKAGE_luci-i18n-opkg-zh-cn=y

# ============================================================
# 存储支持 (/home 分区 + PXE)
# ============================================================
CONFIG_PACKAGE_e2fsprogs=y
CONFIG_PACKAGE_kmod-fs-ext4=y
CONFIG_PACKAGE_kmod-fs-vfat=y
CONFIG_PACKAGE_kmod-nls-utf8=y
CONFIG_PACKAGE_block-mount=y
CONFIG_PACKAGE_blkid=y
CONFIG_PACKAGE_parted=y
CONFIG_PACKAGE_partx=y
CONFIG_PACKAGE_kmod-fs-udf=y
CONFIG_PACKAGE_kmod-cdrom=y
CONFIG_PACKAGE_kmod-lib-crc-itu-t=y
CONFIG_PACKAGE_wimlib=y
CONFIG_PACKAGE_7z=y

# ============================================================
# 系统工具
# ============================================================
CONFIG_PACKAGE_curl=y
CONFIG_PACKAGE_wget=y
CONFIG_PACKAGE_rsync=y
CONFIG_PACKAGE_nano=y
CONFIG_PACKAGE_ethtool=y

# ============================================================
# MgrServer 核心依赖
# ============================================================

# Node.js 22.x (MgrServer 运行时) - 官方 packages 中的可用版本
CONFIG_NODEJS_22=y
CONFIG_NODEJS_ICU_SMALL=y
CONFIG_PACKAGE_node=y
CONFIG_PACKAGE_node-npm=y

# 完全禁用 Node.js 其他版本 (避免编译错误)
# CONFIG_NODEJS_20 is not set
# CONFIG_NODEJS_24 is not set
# CONFIG_NODEJS_25 is not set

# Python3 (MgrServer 脚本功能)
CONFIG_PACKAGE_python3=y
CONFIG_PACKAGE_python3-base=y
CONFIG_PACKAGE_python3-light=y
CONFIG_PACKAGE_python3-asyncio=y
CONFIG_PACKAGE_python3-codecs=y
CONFIG_PACKAGE_python3-ctypes=y
CONFIG_PACKAGE_python3-dbm=y
CONFIG_PACKAGE_python3-decimal=y
CONFIG_PACKAGE_python3-email=y
CONFIG_PACKAGE_python3-logging=y
CONFIG_PACKAGE_python3-lzma=y
CONFIG_PACKAGE_python3-multiprocessing=y
CONFIG_PACKAGE_python3-ncurses=y
CONFIG_PACKAGE_python3-openssl=y
CONFIG_PACKAGE_python3-pip=y
CONFIG_PACKAGE_python3-pkg-resources=y
CONFIG_PACKAGE_python3-pydoc=y
CONFIG_PACKAGE_python3-readline=y
CONFIG_PACKAGE_python3-setuptools=y
CONFIG_PACKAGE_python3-sqlite3=y
CONFIG_PACKAGE_python3-unittest=y
CONFIG_PACKAGE_python3-urllib=y
CONFIG_PACKAGE_python3-uuid=y
CONFIG_PACKAGE_python3-venv=y
CONFIG_PACKAGE_python3-xml=y

# sing-box (预编译 IPK, 见 workflow)
# CONFIG_PACKAGE_sing-box=y

# easytier (预编译 IPK, 见 workflow)
# CONFIG_PACKAGE_easytier=y
# CONFIG_PACKAGE_luci-app-easytier=y

# SSH/SFTP (MgrServer 文件传输)
CONFIG_PACKAGE_openssh-sftp-server=y

# ============================================================
# 无线中继 / Mesh / Repeater
# ============================================================
CONFIG_PACKAGE_relayd=y
CONFIG_PACKAGE_kmod-batman-adv=y
CONFIG_PACKAGE_batctl=y
CONFIG_PACKAGE_bridge=y
CONFIG_PACKAGE_igmpproxy=y
CONFIG_PACKAGE_kmod-nft-bridge=y
CONFIG_PACKAGE_luci-proto-relay=y
CONFIG_PACKAGE_luci-proto-batman_adv=y
