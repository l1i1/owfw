config mgrserver 'main'
  option app_dir '/root/mgrserver'
  option port '80'
  option serve_static '1'
  option static_dir '/root/mgrserver/web-dist'
  option commands_file '/root/mgrserver/commands.json'
  option mgmt_password 'password'
  option cors_origins ''
  option allowed_path_prefixes '/etc,/tmp,/var,/root,/home/pxe'
  option max_file_bytes '2097152'
  option backup_on_write '1'
  option allow_unsafe_exec '0'
  option session_ttl_sec '43200'
  option license_strict '1'
  option license_file '/etc/mgrserver/artifact-license.json'
  option license_sig_file '/etc/mgrserver/artifact-license.sig'
  option license_public_key_file '/etc/mgrserver/license-public.pem'
  option license_check_interval_ms '15000'
