#!/bin/sh /etc/rc.common
# MgrServer init script for OpenWrt with procd
# Features: health check, graceful shutdown, status command, logging

USE_PROCD=1
START=95
STOP=10

SERVICE_NAME="mgrserver"
DEFAULT_APP_DIR="/root/mgrserver"
PIDFILE="/var/run/${SERVICE_NAME}.pid"
HEALTH_CHECK_INTERVAL=30
HEALTH_CHECK_URL="http://127.0.0.1:%s/health"
LOG_DIR="/var/log/mgrserver"
MAX_LOG_SIZE="1M"
MAX_LOG_FILES=3

# Logging helper
log_msg() {
  local level="$1"
  shift
  logger -t "$SERVICE_NAME" -p "daemon.$level" "$@"
  echo "[$(date '+%Y-%m-%d %H:%M:%S')] [$level] $*"
}

# Check if a value is "true"
is_true() {
  local v
  v="$(echo "${1:-}" | tr -d '\r\n\t \\')"
  v="$(echo "$v" | tr 'A-Z' 'a-z')"
  case "$v" in
    1|true|yes|on) return 0 ;;
    *) return 1 ;;
  esac
}

# Quote a string for shell
quote_sh() {
  printf "%s" "$1" | sed "s/'/'\\''/g; 1s/^/'/; \$s/\$/'/"
}

# Setup log directory
setup_logging() {
  mkdir -p "$LOG_DIR"
  chown root:root "$LOG_DIR"
  chmod 755 "$LOG_DIR"
}

# Health check function
do_health_check() {
  local port="$1"
  local url=$(printf "$HEALTH_CHECK_URL" "$port")
  local max_retries=3
  local retry_delay=5
  
  for i in $(seq 1 $max_retries); do
    if command -v curl >/dev/null 2>&1; then
      if curl -s --connect-timeout 5 --max-time 10 "$url" >/dev/null 2>&1; then
        return 0
      fi
    elif command -v wget >/dev/null 2>&1; then
      if wget -q -T 10 -O - "$url" >/dev/null 2>&1; then
        return 0
      fi
    else
      return 1
    fi
    [ $i -lt $max_retries ] && sleep $retry_delay
  done
  
  return 1
}

# Service status command
status_service() {
  local app_dir port
  config_load mgrserver
  config_get app_dir main app_dir "$DEFAULT_APP_DIR"
  config_get port main port "80"
  
  echo "=== MgrServer Status ==="
  echo ""
  
  # Check if service is running
  if procd_running "$SERVICE_NAME"; then
    echo "Status: RUNNING"
    echo "PID: $(cat "$PIDFILE" 2>/dev/null || echo 'N/A')"
  else
    echo "Status: STOPPED"
    return 0
  fi
  
  echo "Port: $port"
  echo "App Dir: $app_dir"
  echo ""
  
  # Health check
  echo "Health Check:"
  if do_health_check "$port"; then
    echo "  HTTP: OK (http://127.0.0.1:$port/health)"
  else
    echo "  HTTP: FAILED"
  fi
  
  echo ""
  
  # Memory usage
  local pid=$(cat "$PIDFILE" 2>/dev/null)
  if [ -n "$pid" ] && [ -d "/proc/$pid" ]; then
    echo "Memory Usage:"
    grep -E '^VmRSS|^VmSize|^VmData' "/proc/$pid/status" 2>/dev/null || echo "  N/A"
    echo ""
    echo "Uptime:"
    ps -o etime= -p "$pid" 2>/dev/null || echo "  N/A"
  fi
  
  echo ""
  echo "Recent Logs:"
  tail -n 10 "$LOG_DIR/daemon.log" 2>/dev/null || echo "  No logs available"
}

# Validate configuration
validate_config() {
  local app_dir port
  
  config_load mgrserver
  config_get app_dir main app_dir "$DEFAULT_APP_DIR"
  config_get port main port "80"
  
  # Check Node.js
  if ! command -v node >/dev/null 2>&1; then
    log_msg "err" "Node.js not found. Install: opkg update && opkg install node"
    return 1
  fi
  
  # Check app directory
  if [ ! -d "$app_dir" ]; then
    log_msg "err" "App directory not found: $app_dir"
    return 1
  fi
  
  # Check server entry
  local server_entry="${app_dir}/bundle/index.cjs"
  if [ ! -f "$server_entry" ]; then
    server_entry="${app_dir}/dist/index.js"
  fi
  
  if [ ! -f "$server_entry" ]; then
    log_msg "err" "Server entry not found: ${app_dir}/bundle/index.cjs or ${app_dir}/dist/index.js"
    return 1
  fi
  
  # Check port availability (use ss instead of deprecated netstat)
  if ss -tuln 2>/dev/null | grep -q ":${port} "; then
    if ! procd_running "$SERVICE_NAME"; then
      log_msg "warn" "Port $port is already in use by another process"
    fi
  fi
  
  return 0
}

start_service() {
  setup_logging
  
  config_load mgrserver

  local app_dir port serve_static static_dir commands_file mgmt_password cors_origins allowed_path_prefixes
  local health_check_enabled log_level

  config_get app_dir main app_dir "$DEFAULT_APP_DIR"
  config_get port main port "80"
  config_get serve_static main serve_static "1"
  config_get static_dir main static_dir "${app_dir}/web-dist"
  config_get commands_file main commands_file "${app_dir}/commands.json"
  config_get allowed_path_prefixes main allowed_path_prefixes "/etc,/rom/etc,/tmp,/var,/root,/home/pxe"
  config_get health_check_enabled main health_check_enabled "1"
  config_get log_level main log_level "info"

  # Default password auth.
  config_get mgmt_password main mgmt_password "password"
  config_get cors_origins main cors_origins ""

  # Validate before starting
  if ! validate_config; then
    log_msg "err" "Configuration validation failed, not starting service"
    return 1
  fi

  local server_entry="${app_dir}/bundle/index.cjs"
  [ ! -f "$server_entry" ] && server_entry="${app_dir}/dist/index.js"

  local serve_static_bool="false"
  [ "$serve_static" = "1" ] && serve_static_bool="true"

  log_msg "info" "Starting MgrServer on port $port"

  procd_open_instance
  procd_set_param cwd "$app_dir"
  procd_set_param pidfile "$PIDFILE"
  
  # Respawn with limits: retry 5 times within 300 seconds
  procd_set_param respawn ${respawn_threshold:-3600} ${respawn_timeout:-5} ${respawn_retry:-5}
  
  # Enable stdout/stderr logging
  procd_set_param stdout 1
  procd_set_param stderr 1
  
  # Set process limits
  procd_set_param limits core="unlimited" nofile="65535 65535"

  # Build command with environment
  cmd=""
  cmd="$cmd NODE_ENV=$(quote_sh production)"
  cmd="$cmd PORT=$(quote_sh "$port")"
  cmd="$cmd SERVE_STATIC=$(quote_sh "$serve_static_bool")"
  cmd="$cmd STATIC_DIR=$(quote_sh "$static_dir")"
  cmd="$cmd MGMT_COMMANDS_FILE=$(quote_sh "$commands_file")"
  cmd="$cmd LOG_LEVEL=$(quote_sh "$log_level")"

  [ -n "$mgmt_password" ] && cmd="$cmd MGMT_PASSWORD=$(quote_sh "$mgmt_password")"
  [ -n "$cors_origins" ] && cmd="$cmd CORS_ORIGINS=$(quote_sh "$cors_origins")"
  
  if ! echo "$allowed_path_prefixes" | grep -q "/home/pxe"; then
    allowed_path_prefixes="${allowed_path_prefixes},/home/pxe"
  fi
  cmd="$cmd ALLOWED_PATH_PREFIXES=$(quote_sh "$allowed_path_prefixes")"

  cmd="$cmd exec node $(quote_sh "$server_entry")"
  procd_set_param command sh -c "$cmd"

  procd_close_instance
  
  log_msg "info" "MgrServer started successfully"
}

stop_service() {
  log_msg "info" "Stopping MgrServer"
  rm -f "$PIDFILE"
}

# Called after service is started
service_started() {
  local port
  config_load mgrserver
  config_get port main port "80"
  
  # Wait for service to be ready
  sleep 2
  
  if do_health_check "$port"; then
    log_msg "info" "MgrServer health check passed"
  else
    log_msg "warn" "MgrServer health check failed, service may not be ready"
  fi
}

# Reload configuration
reload_service() {
  stop
  start
}

# Extra commands
EXTRA_COMMANDS="status health_check validate"
DESC_status="Show detailed service status"
DESC_health_check="Run health check"
DESC_validate="Validate configuration"

# Health check command
health_check() {
  local port
  config_load mgrserver
  config_get port main port "80"
  
  if do_health_check "$port"; then
    echo "Health check: OK"
    return 0
  else
    echo "Health check: FAILED"
    return 1
  fi
}

# Validate command
validate() {
  if validate_config; then
    echo "Configuration: VALID"
    return 0
  else
    echo "Configuration: INVALID"
    return 1
  fi
}
