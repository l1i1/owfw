#!/bin/sh

UPPER_ETC="/overlay/upper/etc"
UPPER_RC_COMMON="$UPPER_ETC/rc.common"
UPPER_RC_COMMON_WHITEOUT="$UPPER_ETC/.wh.rc.common"
ROM_RC_COMMON="/rom/etc/rc.common"

log_message() {
  echo "rcS-guard: $1" > /dev/kmsg 2>/dev/null || true
}

repair_overlay_rc_common() {
  [ -d "$UPPER_ETC" ] || return 1
  [ -f "$ROM_RC_COMMON" ] || return 1

  rm -f "$UPPER_RC_COMMON" "$UPPER_RC_COMMON_WHITEOUT" || return 1
  cp "$ROM_RC_COMMON" "$UPPER_RC_COMMON" || return 1
  chmod 755 "$UPPER_RC_COMMON" || return 1
}

ensure_rc_common() {
  [ -x /etc/rc.common ] && return 0
  [ -c "$UPPER_RC_COMMON" ] || [ -e "$UPPER_RC_COMMON_WHITEOUT" ] || [ ! -e "$UPPER_RC_COMMON" ] || return 0

  log_message "repairing missing /etc/rc.common before rcS"
  repair_overlay_rc_common || {
    log_message "failed to repair overlay rc.common before rcS"
    return 1
  }

  log_message "restored /etc/rc.common before rcS"
  return 0
}

run_rc_scripts() {
  local level="$1"
  local param="$2"
  local script=""

  for script in /etc/rc.d/"$level"*; do
    [ -x "$script" ] || continue
    /bin/sh "$ROM_RC_COMMON" "$script" "$param"
  done
}

[ -f "$ROM_RC_COMMON" ] || exit 1

case "$1" in
  S)
    ensure_rc_common || exit 1
    ;;
esac

run_rc_scripts "$1" "$2"
