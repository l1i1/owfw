#!/bin/sh
# Service Watchdog Script for OpenWrt
# Monitors critical services and restarts them if they fail

LOG_TAG="service-watchdog"
LOG_FILE="/var/log/service-watchdog.log"
MAX_LOG_SIZE="512K"
MAX_LOG_FILES=3
RC_COMMON="/rom/etc/rc.common"

# Services to monitor: name:pidfile:check_action:start_action
# Delegate health verification to the init script so custom ports stay in sync.
SERVICES="mgrserver:/var/run/mgrserver.pid:health_check:restart"

log() {
  local level="$1"
  shift
  local msg="$*"
  logger -t "$LOG_TAG" -p "daemon.$level" "$msg"
  
  # Rotate log if needed
  if [ -f "$LOG_FILE" ]; then
    local size=$(du -k "$LOG_FILE" 2>/dev/null | cut -f1)
    if [ -n "$size" ] && [ "$size" -gt 512 ]; then
      mv "$LOG_FILE" "$LOG_FILE.1" 2>/dev/null
    fi
  fi
  
  echo "$(date '+%Y-%m-%d %H:%M:%S') [$level] $msg" >> "$LOG_FILE"
}

run_init_script() {
  local name="$1"
  shift
  local script="/etc/init.d/$name"

  [ -f "$script" ] || return 127

  if [ -f "$RC_COMMON" ]; then
    /bin/sh "$RC_COMMON" "$script" "$@"
    return $?
  fi

  "$script" "$@"
}

# Check if a service is healthy
check_service() {
  local name="$1"
  local pidfile="$2"
  local check_action="$3"
  local pid_ok=0

  # Check if PID file exists and process is running
  if [ -n "$pidfile" ] && [ -f "$pidfile" ]; then
    local pid=$(cat "$pidfile")
    if [ -n "$pid" ] && [ -d "/proc/$pid" ]; then
      pid_ok=1
    else
      log "warn" "$name: PID $pid not running"
    fi
  elif [ -n "$pidfile" ]; then
    log "warn" "$name: PID file not found"
  fi

  # Run custom health check if provided
  if [ -n "$check_action" ]; then
    if run_init_script "$name" "$check_action" >/dev/null 2>&1; then
      return 0
    fi
    log "warn" "$name: health check failed"
    return 1
  fi

  if [ "$pid_ok" = "1" ]; then
    return 0
  fi

  return 1
}

# Restart a service
restart_service() {
  local name="$1"
  local start_action="$2"

  log "info" "$name: attempting restart"

  if run_init_script "$name" "$start_action" >/dev/null 2>&1; then
    log "info" "$name: restart successful"
    return 0
  else
    log "err" "$name: restart failed"
    return 1
  fi
}

# Main watchdog loop
main() {
  log "info" "Service watchdog started"

  for service in $SERVICES; do
    # Parse service definition (avoid bash here-string)
    name="${service%%:*}"
    rest="${service#*:}"
    pidfile="${rest%%:*}"
    rest="${rest#*:}"
    check_action="${rest%%:*}"
    start_action="${rest#*:}"

    if ! check_service "$name" "$pidfile" "$check_action"; then
      log "warn" "$name: service unhealthy, restarting..."
      restart_service "$name" "$start_action"
    fi
  done

  log "info" "Service watchdog check completed"
}

# Run main function
main "$@"
